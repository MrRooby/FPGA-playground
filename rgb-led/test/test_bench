`timescale 1ns / 1ps

module testbench;
    localparam integer CLK_HALF_NS = 18; // ~27 MHz

    reg  clk  = 1'b0;
    reg  btn1 = 1'b0; // currently unused by top.v
    wire rgb_led;

    integer start_pulses = 0;

    // DUT: top-level module (matches current top.v ports)
    top dut (
        .rgb_led(rgb_led),
        .clk(clk),
        .btn1(btn1)
    );

    always #CLK_HALF_NS clk = ~clk;

    // Observe internal start activity from top
    always @(posedge clk) begin
        if (dut.start)
            start_pulses <= start_pulses + 1;
    end

    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, testbench);

        // Let design run
        repeat (250000) @(posedge clk);

        $display("INFO: start_pulses=%0d busy=%0b rgb_led=%0b", start_pulses, dut.busy, rgb_led);

        // Simple smoke check for current auto-start behavior
        if (start_pulses < 1) begin
            $display("FAIL: expected at least one start pulse");
            $fatal(1);
        end else begin
            $display("PASS: top.v generated start activity");
        end

        $finish;
    end
endmodule